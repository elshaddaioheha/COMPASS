# .env.example
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Flask ──────────────────────────────────────────────────────────────────
FLASK_ENV=production
SECRET_KEY=replace-with-a-long-random-string
PORT=5000

# ── MongoDB ────────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/
MONGO_DB_NAME=mental_health_chatbot
MONGO_COLLECTION=conversations

# ── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=20
SESSION_TTL_SECONDS=1800
PREDICTION_CACHE_TTL=60

# ── Model ──────────────────────────────────────────────────────────────────
MODEL_DIR=./distilbert_finetuned
USE_ONNX=true
ONNX_MODEL_PATH=./onnx_model/model_quantized.onnx
LABELS_PATH=./label_classes.json

# ── NLP settings ───────────────────────────────────────────────────────────
CONFIDENCE_THRESHOLD=0.55
MAX_INPUT_LENGTH=512
MAX_RAW_CHARS=1000
SPACY_MODEL=en_core_web_sm

# ── Rate limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS=30
RATE_LIMIT_WINDOW_SECONDS=60

# ── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
FRONTEND_ORIGINS=http://localhost:3000,https://compass-two-iota.vercel.app,https://compaass.vercel.app,https://compass-frontend.onrender.com

# ── Hugging Face Hub ────────────────────────────────────────────────────────
HF_MODEL_REPO=Oheha/compass-emotion-classifier
HF_TOKEN=your_hugging_face_write_token_here

# ── Multilingual translation settings ───────────────────────────────────────
ENABLE_MULTILINGUAL=false
SUPPORTED_LANGUAGES=en,yo,pcm
LANGUAGE_TRANSLATION_PROVIDER=groq
LANGUAGE_TRANSLATION_TIMEOUT_SECONDS=8.0

