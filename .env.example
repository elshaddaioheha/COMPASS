# .env.example — COMPASS frontend
# ---------------------------------------------------------------------------
# Copy this to `.env.local` for local development:   cp .env.example .env.local
# On Vercel, set NEXT_PUBLIC_API_URL in Project → Settings → Environment Variables.
# ---------------------------------------------------------------------------

# Base URL of the COMPASS Flask backend (no trailing slash).
# Local backend:   http://localhost:5000
# Render backend:  https://your-compass-backend.onrender.com
NEXT_PUBLIC_API_URL=http://localhost:5000

# ---------------------------------------------------------------------------
# Backend Config (for c:\Users\HP\Desktop\COMPASS-frontend\backend\.env)
# ---------------------------------------------------------------------------

# Flask Settings
# FLASK_ENV=production
# SECRET_KEY=replace-with-a-long-random-string
# PORT=5000

# MongoDB Settings
# MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/
# MONGO_DB_NAME=mental_health_chatbot
# MONGO_COLLECTION=conversations

# Redis Settings
# REDIS_URL=redis://localhost:6379/0
# REDIS_MAX_CONNECTIONS=20
# SESSION_TTL_SECONDS=1800
# PREDICTION_CACHE_TTL=60

# Model Settings
# MODEL_DIR=./distilbert_finetuned
# USE_ONNX=true
# ONNX_MODEL_PATH=./onnx_model/model_quantized.onnx
# LABELS_PATH=./label_classes.json

# NLP settings
# CONFIDENCE_THRESHOLD=0.55
# MAX_INPUT_LENGTH=512
# MAX_RAW_CHARS=1000
# SPACY_MODEL=en_core_web_sm

# Rate limiting
# RATE_LIMIT_REQUESTS=30
# RATE_LIMIT_WINDOW_SECONDS=60

# Groq LLM Settings
# GROQ_API_KEY=gsk_your_groq_key_here
# GROQ_MODEL=llama-3.1-8b-instant

# CORS Configurations
# FRONTEND_ORIGINS=http://localhost:3000,https://compass-two-iota.vercel.app,https://compaass.vercel.app,https://compass-frontend.onrender.com

# Hugging Face Hub
# HF_MODEL_REPO=Oheha/compass-emotion-classifier
# HF_TOKEN=your_hugging_face_write_token_here

# Multilingual translation settings
# ENABLE_MULTILINGUAL=false
# SUPPORTED_LANGUAGES=en,yo,pcm
# LANGUAGE_TRANSLATION_PROVIDER=groq
# LANGUAGE_TRANSLATION_TIMEOUT_SECONDS=8.0

