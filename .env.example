# .env.example — COMPASS frontend
# ---------------------------------------------------------------------------
# Copy this to `.env.local` for local development:   cp .env.example .env.local
# On Vercel, set NEXT_PUBLIC_API_URL in Project → Settings → Environment Variables.
# ---------------------------------------------------------------------------

# Base URL of the COMPASS Flask backend (no trailing slash).
# Local backend:   http://localhost:5000
# Render backend:  https://your-compass-backend.onrender.com
NEXT_PUBLIC_API_URL=http://localhost:5000
